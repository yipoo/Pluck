    <channel>
        <title>Pluck</title>
        <link>https://pluck.yipoo.com/appcast.xml</link>
        <description>Pluck 自动更新源 — 由 Sparkle 框架轮询;描述 macOS 14+ 各版本的发布、变更、签名信息。</description>
        <language>zh-CN</language>

        <!--
        ===== 关于本文件 =====

        Sparkle 自动更新框架会按 SUFeedURL 轮询此 XML(默认每 24h)。
        每次发新版,在最前面增加一个 <item>,把 sparkle:edSignature 用 sign_update 工具生成后填入。

        生成签名:
            /path/to/sparkle/bin/sign_update path/to/Pluck-X.Y.Z.dmg
            (输出形如:sparkle:edSignature="..." length="...")

        私钥在 Keychain,保密;公钥已写在 Pluck.app 的 Info.plist (SUPublicEDKey)。

        每个 <item> 的 enclosure URL 走我们 Vercel Function 代理 → Vercel Blob,
        实际文件由 Vercel 边缘 CDN 服务,无需 hot-link 到 blob.vercel-storage.com。
        -->

        <item>
            <title>Pluck 0.1.0</title>
            <pubDate>Sat, 21 Jun 2026 12:00:00 +0800</pubDate>
            <sparkle:version>1</sparkle:version>
            <sparkle:shortVersionString>0.1.0</sparkle:shortVersionString>
            <sparkle:minimumSystemVersion>14.0</sparkle:minimumSystemVersion>
            <sparkle:fullReleaseNotesLink>https://pluck.yipoo.com/changelog.html</sparkle:fullReleaseNotesLink>
            <sparkle:releaseNotesLink>https://pluck.yipoo.com/release-notes/0.1.0.html</sparkle:releaseNotesLink>
            <description><![CDATA[
                <h2>v0.1.0 — 首个公开版本</h2>

                <h3>核心功能</h3>
                <ol>
                    <li>全局热键 Control + Option + A 区域截图 + Apple Vision 自动 OCR(中文 95%+)</li>
                    <li>全局热键 Control + Option + V 打开剪贴板历史</li>
                    <li>多屏环境智能识别鼠标所在屏幕</li>
                    <li>截图视觉反馈(白光淡出 + 系统音效)</li>
                    <li>动态菜单栏图标三态</li>
                    <li>3 步首启 Onboarding</li>
                </ol>

                <h3>标注与长截图</h3>
                <ol>
                    <li>矩形 / 箭头 / 高亮 / 文本 4 种标注工具</li>
                    <li>长截图(实验性):滚动捕获 + 自动拼接</li>
                </ol>

                <h3>隐私</h3>
                <ol>
                    <li>默认不申请网络权限</li>
                    <li>不内嵌任何分析 / 崩溃 / 广告 SDK</li>
                    <li>所有数据本地处理</li>
                </ol>

                <p><a href="https://pluck.yipoo.com/changelog.html">完整更新日志</a></p>
            ]]></description>
            <enclosure
                url="https://pluck.yipoo.com/dl/Pluck-0.1.0.dmg"
                sparkle:edSignature="__REPLACE_WITH_sign_update_OUTPUT__"
                length="8388608"
                type="application/octet-stream"/>
        </item>

